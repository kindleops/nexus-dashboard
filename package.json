{
  "name": "nexus-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "setup:inbox": "node scripts/setup-inbox.mjs",
    "proof:inbox": "node scripts/proof/inbox-proof.mjs",
    "proof:inbox-integrity": "node scripts/proof/inbox-integrity.mjs",
    "proof:smart-inboxes": "node scripts/proof/smart-inboxes.mjs",
    "proof:inbox-buttons": "node scripts/proof/inbox-buttons.mjs",
    "proof:queue": "node scripts/proof/queue-proof.mjs",
    "proof:inbox-backfill": "node scripts/proof/inbox-backfill.mjs",
    "proof:copilot-ui": "node scripts/proof-copilot-ui.mjs",
    "proof:system": "node scripts/proof-inbox.mjs && node scripts/proof-classifier.mjs && node scripts/proof-thread-counts.mjs && node scripts/proof-routing.mjs",
    "proof": "npm run proof:system && npm run proof:inbox-integrity && npm run proof:copilot-ui"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.1",
    "@types/react-window": "^1.8.8",
